PORT=8083

# Auth service (local sin Docker; en Docker lo fija docker-compose.yml)
AUTH_SERVICE_BASE_URL=http://localhost:8082

# Eureka Server (local sin Docker; en Docker lo fija docker-compose.yml)
EUREKA_SERVER_URL=http://localhost:8761/eureka

# Neon PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host/neondb?user=...&password=...&sslmode=require
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# CloudAMQP RabbitMQ
RABBITMQ_HOST=beaver.rmq.cloudamqp.com
RABBITMQ_PORT=5671
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=
RABBITMQ_SSL_ENABLED=true
RABBITMQ_EXCHANGE=paper.events
RABBITMQ_ROUTING_KEY_EVALUATED=paper.evaluated

FRONTEND_URL=http://localhost:5173
JWT_PUBLIC_KEY=replace-with-rsa-public-key-base64

# Backblaze B2
BACKBLAZE_ENDPOINT=s3.us-west-004.backblazeb2.com
BACKBLAZE_REGION=us-west-004
BACKBLAZE_BUCKET_NAME=paper-service
BACKBLAZE_ACCESS_KEY=
BACKBLAZE_SECRET_KEY=
